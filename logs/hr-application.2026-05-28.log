(B.OT_TYPE_CODE, 'vi') AS OT_TYPE_NAME, TO_CHAR(B.OT_APPLY_HOUR) AS OT_APPLY_HOUR, TO_CHAR(B.AFFIRM_FLAG) AS AFFIRM_FLAG, GET_GLOBAL_NAME(B.AFFIRM_FLAG, 'vi') AS AFFIRM_FLAG_NAME, TO_CHAR(B.CONFIRM_FLAG) AS CONFIRM_FLAG, TO_CHAR(B.CREATE_DATE, 'YYYY-MM-DD HH24:MI:SS') AS CREATE_DATE, GET_UPDATED_INFO(B.CREATED_BY) AS CREATED_BY, B.CREATED_IP, TO_CHAR(B.UPDATE_DATE, 'YYYY-MM-DD HH24:MI:SS') AS UPDATE_DATE, GET_UPDATED_INFO(B.UPDATED_BY) AS UPDATED_BY, B.UPDATED_IP, B.ACTIVITY AS ACTIVITY, TO_CHAR(B.APPLY_TIME, 'YYYY-MM-DD HH24:MI:SS') AS APPLY_TIME, TO_CHAR(B.CONFIRM_DATE, 'YYYY-MM-DD HH24:MI:SS') AS CONFIRM_DATE, B.CONFIRM_BY, B.CONFIRM_IP, B.CPNY_ID, B.BATCH_YN AS BATCH_YN, B.BATCH_NO AS BATCH_NO, B.DEDUCT_YN AS DEDUCT_YN, B.SPECIAL_YN AS SPECIAL_YN, B.OFFSET_YN AS OFFSET_YN, B.ADJUST_YN AS ADJUST_YN, TO_CHAR(B.OT_FROM_TIME, 'YYYY-MM-DD HH24:MI') AS DETAIL_FROM_DATE_TIME, TO_CHAR(B.OT_TO_TIME, 'YYYY-MM-DD HH24:MI') AS DETAIL_TO_DATE_TIME, GET_AR_MAC_TIME(B.PERSON_ID, TO_CHAR(B.APPLY_OT_DATE, 'YYYY-MM-DD'), 'IN') AS INDOOR_TIME, GET_AR_MAC_TIME(B.PERSON_ID, TO_CHAR(B.APPLY_OT_DATE, 'YYYY-MM-DD'), 'OUT') AS OUTDOOR_TIME, GET_AR_OT_TOTAIL(TO_CHAR(B.APPLY_OT_DATE, 'YYYY/MM/DD'), B.CPNY_ID, B.PERSON_ID, '30') AS OT_TOTAL_MONTH, GET_AR_OT_TOTAIL(TO_CHAR(B.APPLY_OT_DATE, 'YYYY/MM/DD'), B.CPNY_ID, B.PERSON_ID, '200') AS OT_TOTAL_YEAR, AGG.AFFIRM_STR FROM FILTERED_OT B LEFT JOIN AFFIRM_AGG_DATA AGG ON B.APPLY_NO = AGG.APPLY_NO ORDER BY B.CREATE_DATE DESC, B.EMPID
